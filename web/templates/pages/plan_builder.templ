package pages

import "github.com/hakken/hakken/web/templates/layouts"

templ PlanBuilder(csrfToken string, step int, generatedPrompt string, data map[string]string) {
	@layouts.Base("Plan with AI", csrfToken) {
		<div class="page-header">
			<a href="/trips/new" class="btn btn-ghost btn-sm"><sl-icon name="arrow-left"></sl-icon> Back</a>
			<h1 class="page-title">Plan New Trip with AI</h1>
		</div>
		<div class="wizard-steps">
			<div class={ "wizard-step", templ.KV("active", step == 1), templ.KV("done", step > 1) }>
				<span class="step-num">1</span>
				<span class="step-label">Trip basics</span>
			</div>
			<div class="wizard-step-divider"></div>
			<div class={ "wizard-step", templ.KV("active", step == 2), templ.KV("done", step > 2) }>
				<span class="step-num">2</span>
				<span class="step-label">Personalize</span>
			</div>
			<div class="wizard-step-divider"></div>
			<div class={ "wizard-step", templ.KV("active", step == 3) }>
				<span class="step-num">3</span>
				<span class="step-label">Your prompt</span>
			</div>
		</div>
		<div id="wizard-content">
			if step == 1 {
				@planStep1(csrfToken, data)
			} else if step == 2 {
				@planStep2(csrfToken, data)
			} else {
				@planStep3(csrfToken, generatedPrompt)
			}
		</div>
	}
}

templ planStep1(csrfToken string, data map[string]string) {
	<div class="form-card">
		<h2 class="form-section-title">Step 1 — Trip basics</h2>
		<p class="form-help">Tell us where and when you're going. We'll use this to build a personalised planning prompt.</p>
		<form
			method="POST"
			action="/trips/new/plan"
			hx-post="/trips/new/plan"
			hx-target="#wizard-content"
			hx-swap="outerHTML"
			hx-select="#wizard-content"
			class="form-stack"
		>
			<input type="hidden" name="gorilla.csrf.Token" value={ csrfToken }/>
			<input type="hidden" name="step" value="1"/>
			<div class="field">
				<label class="field-label" for="destinations">Destinations <span class="required">*</span></label>
				<textarea
					class="field-textarea"
					id="destinations"
					name="destinations"
					required
					placeholder="e.g. Tokyo → Kyoto → Osaka, or just a single destination"
					rows="3"
				>{ dataVal(data, "destinations") }</textarea>
			</div>
			<div class="field-row">
				<div class="field">
					<label class="field-label" for="start_date">Start date <span class="required">*</span></label>
					<input class="field-input" type="date" id="start_date" name="start_date" required value={ dataVal(data, "start_date") }/>
				</div>
				<div class="field">
					<label class="field-label" for="end_date">End date <span class="required">*</span></label>
					<input class="field-input" type="date" id="end_date" name="end_date" required value={ dataVal(data, "end_date") }/>
				</div>
			</div>
			<div class="field-row">
				<div class="field">
					<label class="field-label" for="travellers_count">Number of travellers <span class="required">*</span></label>
					<input class="field-input" type="number" id="travellers_count" name="travellers_count" required min="1" placeholder="2" value={ dataVal(data, "travellers_count") }/>
				</div>
				<div class="field">
					<label class="field-label" for="travellers_ages">Ages of travellers <span class="field-optional">(optional)</span></label>
					<input class="field-input" type="text" id="travellers_ages" name="travellers_ages" placeholder="e.g. 35, 34, 8" value={ dataVal(data, "travellers_ages") }/>
					<p class="field-hint">Helps AI calibrate pace and activities.</p>
				</div>
			</div>
			<div class="field">
				<label class="field-label" for="home_city">Home city <span class="field-optional">(optional)</span></label>
				<input class="field-input" type="text" id="home_city" name="home_city" placeholder="e.g. London" value={ dataVal(data, "home_city") }/>
				<p class="field-hint">Helps AI suggest routing from your origin.</p>
			</div>
			<div class="field">
				<sl-radio-group name="intensity" label="Trip intensity" value={ intensityOrDefault(data) }>
					<sl-radio-button value="maximize">Maximize sightseeing</sl-radio-button>
					<sl-radio-button value="balanced">Balanced</sl-radio-button>
					<sl-radio-button value="relaxed">Relaxed</sl-radio-button>
				</sl-radio-group>
				<p class="field-hint">Calibrates the number and pace of activities the AI plans per day.</p>
			</div>
			<div class="form-actions">
				<button type="submit" class="btn btn-primary">Next <sl-icon name="arrow-right"></sl-icon></button>
			</div>
		</form>
	</div>
}

templ planStep2(csrfToken string, data map[string]string) {
	<div class="form-card">
		<h2 class="form-section-title">Step 2 — Personalize</h2>
		<p class="form-help">Fine-tune the AI's approach. Check optional fields to expand them.</p>
		<form
			method="POST"
			action="/trips/new/plan"
			hx-post="/trips/new/plan"
			hx-target="#wizard-content"
			hx-swap="outerHTML"
			hx-select="#wizard-content"
			class="form-stack"
		>
			<input type="hidden" name="gorilla.csrf.Token" value={ csrfToken }/>
			<input type="hidden" name="step" value="2"/>
			<input type="hidden" name="destinations" value={ dataVal(data, "destinations") }/>
			<input type="hidden" name="start_date" value={ dataVal(data, "start_date") }/>
			<input type="hidden" name="end_date" value={ dataVal(data, "end_date") }/>
			<input type="hidden" name="home_city" value={ dataVal(data, "home_city") }/>
			<input type="hidden" name="travellers_count" value={ dataVal(data, "travellers_count") }/>
			<input type="hidden" name="travellers_ages" value={ dataVal(data, "travellers_ages") }/>
			<input type="hidden" name="intensity" value={ dataVal(data, "intensity") }/>
			<div class="field">
				<label class="field-label" for="must_sees">Must-sees <span class="required">*</span></label>
				<p class="field-hint">What absolutely cannot be missed?</p>
				<textarea
					class="field-textarea"
					id="must_sees"
					name="must_sees"
					required
					placeholder="e.g. Mount Fuji day trip, Fushimi Inari at dawn, Dotonbori at night..."
					rows="4"
				>{ dataVal(data, "must_sees") }</textarea>
			</div>
			<div class="optional-fields">
				<div class="opt-toggle-row">
					<label class="checkbox-item">
						<input
							type="checkbox"
							name="show_nice_to_haves"
							hx-get="/trips/new/plan/field?field=nice_to_haves"
							hx-include="[name='show_nice_to_haves']"
							hx-target="#opt-nice-to-haves"
							hx-trigger="change"
							hx-swap="innerHTML"
							hx-select=".opt-field-wrap"
						/> Nice-to-haves
					</label>
					<div id="opt-nice-to-haves"></div>
				</div>
				<div class="opt-toggle-row">
					<label class="checkbox-item">
						<input
							type="checkbox"
							name="show_things_to_avoid"
							hx-get="/trips/new/plan/field?field=things_to_avoid"
							hx-include="[name='show_things_to_avoid']"
							hx-target="#opt-things-to-avoid"
							hx-trigger="change"
							hx-swap="innerHTML"
							hx-select=".opt-field-wrap"
						/> Things to avoid
					</label>
					<div id="opt-things-to-avoid"></div>
				</div>
				<div class="opt-toggle-row">
					<label class="checkbox-item">
						<input
							type="checkbox"
							name="show_max_travel_time"
							hx-get="/trips/new/plan/field?field=max_travel_time"
							hx-include="[name='show_max_travel_time']"
							hx-target="#opt-max-travel-time"
							hx-trigger="change"
							hx-swap="innerHTML"
							hx-select=".opt-field-wrap"
						/> Max comfortable travel time between stops
					</label>
					<div id="opt-max-travel-time"></div>
				</div>
				<div class="opt-toggle-row">
					<label class="checkbox-item">
						<input
							type="checkbox"
							name="show_poi_interests"
							hx-get="/trips/new/plan/field?field=poi_interests"
							hx-include="[name='show_poi_interests']"
							hx-target="#opt-poi-interests"
							hx-trigger="change"
							hx-swap="innerHTML"
							hx-select=".opt-field-wrap"
						/> Suggest points of interest along the route
					</label>
					<p class="field-hint">Describe specific interests, accessibility needs, dietary requirements, etc. AI will suggest matching POIs en route.</p>
					<div id="opt-poi-interests"></div>
				</div>
			</div>
			<div class="form-actions">
				<button type="submit" class="btn btn-primary">Generate prompt <sl-icon name="stars"></sl-icon></button>
			</div>
		</form>
	</div>
}

templ PlanOptionalField(field string, show bool) {
	<div class="opt-field-wrap">
		if show {
			if field == "nice_to_haves" {
				<textarea
					class="field-textarea field-textarea-sm opt-field"
					name="nice_to_haves"
					placeholder="e.g. Nishiki Market, teamLab Borderless, a ryokan night..."
					rows="3"
				></textarea>
			} else if field == "things_to_avoid" {
				<textarea
					class="field-textarea field-textarea-sm opt-field"
					name="things_to_avoid"
					placeholder="e.g. tourist trap restaurants, overnight buses, crowded theme parks..."
					rows="3"
				></textarea>
			} else if field == "max_travel_time" {
				<input
					class="field-input opt-field"
					type="text"
					name="max_travel_time"
					placeholder="e.g. 2 hours by train, no overnight travel"
				/>
			} else if field == "poi_interests" {
				<textarea
					class="field-textarea field-textarea-sm opt-field"
					name="poi_interests"
					placeholder="e.g. wheelchair accessible only, vegetarian dining, historical temples over modern attractions..."
					rows="3"
				></textarea>
			}
		}
	</div>
}

templ planStep3(csrfToken string, prompt string) {
	<div class="form-card">
		<h2 class="form-section-title">Step 3 — Your AI planning prompt</h2>
		<div class="prompt-instructions">
			<ol class="instruction-steps">
				<li>Copy the prompt below and paste it into your preferred AI (ChatGPT, Claude, Gemini, etc.)</li>
				<li>Answer any follow-up questions the AI asks to further personalize your trip</li>
				<li>Confirm the day-by-day summary the AI shows you — request changes if needed</li>
				<li>Once you're happy, tell the AI to output the JSON (e.g. "generate JSON")</li>
				<li>Click <strong>Import the result</strong> below and paste the JSON</li>
			</ol>
		</div>
		<div class="prompt-box-wrapper">
			<div class="prompt-box-header">
				<span class="prompt-box-label">Prompt to copy</span>
				<button class="btn btn-sm btn-ghost" onclick="copyPrompt()" id="copy-btn">
					<sl-icon name="clipboard"></sl-icon> Copy prompt
				</button>
			</div>
			<pre class="prompt-box" id="prompt-text">{ prompt }</pre>
		</div>
		<div class="form-actions">
			<a href="/trips/new/plan" class="btn btn-ghost">Start over</a>
			<a href="/trips/new/import" class="btn btn-primary">
				<sl-icon name="file-earmark-arrow-down"></sl-icon> Import the result
			</a>
		</div>
	</div>
}

func intensityOrDefault(data map[string]string) string {
	if v := data["intensity"]; v != "" {
		return v
	}
	return "maximize"
}
