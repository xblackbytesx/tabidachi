FROM golang:1.25-alpine

RUN apk add --no-cache git curl nodejs npm

WORKDIR /app

RUN go install github.com/a-h/templ/cmd/templ@v0.3.1001
RUN go install github.com/air-verse/air@latest

# Install front-end deps; anonymous volume in compose keeps vendor assets alive under the bind-mount.
COPY web/package.json ./web/
RUN npm install --prefix ./web && \
    mkdir -p web/static/vendor && \
    cp web/node_modules/htmx.org/dist/htmx.min.js web/static/vendor/htmx.min.js && \
    cp web/node_modules/sortablejs/Sortable.min.js web/static/vendor/sortable.min.js && \
    rm -rf web/node_modules

EXPOSE 8080

CMD ["air", "-c", "docker/.air.toml"]
