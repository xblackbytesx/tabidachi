# Copy to .env and fill in values

# PostgreSQL
DB_PASSWORD=changeme

# Session cookie secret (min 32 chars, random)
SESSION_SECRET=change-me-to-a-random-32-char-string!!

# CSRF protection key (min 32 chars, random)
CSRF_AUTH_KEY=change-me-to-another-32-char-string!

# App public URL (used for CSRF trusted origins)
APP_BASE_URL=https://hakken.example.com

# Set to true in production (HTTPS)
SECURE_COOKIES=true

# Docker host path for database volume (production)
DOCKER_ROOT=/opt/docker
